.container {
  min-height: 100vh;
  background: #f8f9fa;
}

/* 渐变头部 */
.user-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 32rpx 100rpx;
  color: white;
  text-align: center;
}

.user-header-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 头像 */
.avatar-wrap {
  position: relative;
  display: inline-block;
  margin-bottom: 20rpx;
}

.user-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255,255,255,0.3);
  background: white;
}

.avatar-mask {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 56rpx;
  height: 56rpx;
  background: rgba(0,0,0,0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border: 4rpx solid rgba(255,255,255,0.3);
}

.avatar-edit {
  font-size: 28rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.user-name {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.user-username {
  font-size: 26rpx;
  opacity: 0.8;
}

/* 内容区域 */
.content {
  padding: 0 24rpx;
  margin-top: -60rpx;
  padding-bottom: 40rpx;
}

/* 登录卡片 */
.login-card {
  background: white;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.08);
  text-align: center;
}

.btn-login {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 44rpx;
  padding: 28rpx 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.4);
  margin-bottom: 24rpx;
}

.btn-login:active {
  transform: translateY(4rpx);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.btn-login-icon {
  font-size: 36rpx;
}

.btn-login-text {
  color: white;
  font-weight: 600;
  font-size: 32rpx;
}

.login-tip {
  color: #9ca3af;
  font-size: 26rpx;
}

/* 统计卡片 */
.stats-card {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.08);
  margin-bottom: 24rpx;
}

.stats-item {
  text-align: center;
  flex: 1;
}

.stats-item:active {
  opacity: 0.7;
}

.stats-number {
  font-size: 48rpx;
  font-weight: 700;
  color: #1f2937;
  display: block;
}

.stats-label {
  font-size: 26rpx;
  color: #9ca3af;
  margin-top: 8rpx;
  display: block;
}

.stats-divider {
  width: 2rpx;
  height: 80rpx;
  background: #e5e7eb;
}

/* 菜单卡片 */
.menu-card {
  background: white;
  border-radius: 24rpx;
  padding: 16rpx 8rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.06);
  margin-bottom: 24rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
}

.menu-item:active {
  background: #f9fafb;
  border-radius: 16rpx;
}

.menu-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.menu-icon-green {
  background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
}

.menu-icon-purple {
  background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);
}

.menu-icon-orange {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
}

.menu-icon-pink {
  background: linear-gradient(135deg, #fce7f3 0%, #fbcfe8 100%);
}

.menu-icon-gray {
  background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #374151;
  font-weight: 500;
}

.menu-arrow {
  color: #9ca3af;
  font-size: 36rpx;
  font-weight: 300;
}

.menu-divider {
  height: 2rpx;
  background: #f3f4f6;
  margin: 0 24rpx;
}

/* 退出登录 */
.logout-wrap {
  text-align: center;
  padding: 40rpx;
}

.logout-text {
  color: #ef4444;
  font-size: 28rpx;
  font-weight: 500;
}

.logout-text:active {
  opacity: 0.7;
}
