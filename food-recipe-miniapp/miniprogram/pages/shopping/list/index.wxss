.container {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 160rpx;
}

/* 渐变头部 */
.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 32rpx 60rpx;
  position: relative;
}

.header-content {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 内容区 */
.content {
  margin-top: -30rpx;
  padding: 0 24rpx;
  position: relative;
  z-index: 1;
}

/* Tab切换 */
.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.tab-item {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #6b7280;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
  font-weight: 500;
}

/* 统计卡片 */
.stats-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stats-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #667eea;
  margin-bottom: 8rpx;
}

.stats-num.purchased {
  color: #10b981;
}

.stats-num.pending {
  color: #f59e0b;
}

.stats-label {
  font-size: 24rpx;
  color: #9ca3af;
}

.stats-divider {
  width: 2rpx;
  height: 60rpx;
  background: #e5e7eb;
}

/* 分类筛选 */
.category-scroll {
  margin-bottom: 24rpx;
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  gap: 16rpx;
}

.category-item {
  padding: 14rpx 32rpx;
  background: #fff;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #6b7280;
  border: 2rpx solid transparent;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.category-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

/* 分组卡片 */
.section-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f3f4f6;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  flex: 1;
}

.section-count {
  font-size: 24rpx;
  color: #fff;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

/* 清单列表 */
.shopping-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.shopping-item {
  display: flex;
  align-items: center;
  background: #f9fafb;
  border-radius: 16rpx;
  padding: 20rpx;
  transition: all 0.2s;
}

.shopping-item.purchased {
  opacity: 0.7;
  background: #f3f4f6;
}

.checkbox {
  margin-right: 20rpx;
  padding: 8rpx;
}

.check-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 4rpx solid #d1d5db;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.check-circle.checked {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: transparent;
}

.check-mark {
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.item-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.item-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1f2937;
}

.item-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

/* 分类标签颜色 */
.tag-vegetable {
  background: #dcfce7;
  color: #166534;
}

.tag-meat {
  background: #fee2e2;
  color: #991b1b;
}

.tag-seafood {
  background: #dbeafe;
  color: #1e40af;
}

.tag-egg {
  background: #fef3c7;
  color: #92400e;
}

.tag-fruit {
  background: #fce7f3;
  color: #be185d;
}

.tag-seasoning {
  background: #f3e8ff;
  color: #7c3aed;
}

.tag-staple {
  background: #ffedd5;
  color: #c2410c;
}

.tag-other {
  background: #f3f4f6;
  color: #6b7280;
}

.item-quantity {
  font-size: 24rpx;
  color: #9ca3af;
}

.strikethrough {
  text-decoration: line-through;
  color: #9ca3af;
}

.delete-btn {
  padding: 12rpx;
  margin-left: 8rpx;
}

.delete-icon {
  font-size: 32rpx;
  opacity: 0.6;
}

/* 一键入库按钮 */
.batch-stock-section {
  margin: 32rpx 0 120rpx;
}

.batch-stock-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.batch-stock-btn .btn-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.batch-stock-btn .btn-text {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #667eea20 0%, #764ba220 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #9ca3af;
}

/* 历史列表 */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.history-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-date-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.history-date {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.history-badge {
  background: linear-gradient(135deg, #667eea15 0%, #764ba215 100%);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.history-count {
  font-size: 24rpx;
  color: #667eea;
  font-weight: 500;
}

.history-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #667eea;
  padding: 12rpx 24rpx;
  background: #f3f4f6;
  border-radius: 28rpx;
}

.history-btn .btn-icon {
  font-size: 24rpx;
}

.history-items {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.history-item-name {
  font-size: 24rpx;
  color: #6b7280;
  background: #f9fafb;
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
}

/* 悬浮添加按钮 */
.fab-btn {
  position: fixed;
  bottom: 120rpx;
  right: 40rpx;
  width: 112rpx;
  height: 112rpx;
  z-index: 100;
}

.fab-inner {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.5);
  transition: all 0.3s;
}

.fab-btn:active .fab-inner {
  transform: scale(0.95) rotate(45deg);
  box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.4);
}

.fab-icon {
  color: #fff;
  font-size: 56rpx;
  font-weight: 200;
  line-height: 1;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 84%;
  background: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #f3f4f6;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f2937;
}

.modal-close {
  font-size: 36rpx;
  color: #9ca3af;
  padding: 8rpx;
}

.modal-body {
  padding: 32rpx;
}

/* 入库弹窗特殊样式 */
.stock-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0 40rpx;
}

.stock-num {
  font-size: 72rpx;
  font-weight: 700;
  color: #667eea;
  line-height: 1;
}

.stock-text {
  font-size: 28rpx;
  color: #9ca3af;
  margin-top: 8rpx;
}

/* 输入框 */
.input-wrap {
  margin-bottom: 24rpx;
}

.input-wrap:last-child {
  margin-bottom: 0;
}

.input-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #374151;
  margin-bottom: 12rpx;
}

.modal-input {
  height: 88rpx;
  background: #f9fafb;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #1f2937;
}

/* Picker */
.picker {
  height: 88rpx;
  background: #f9fafb;
  border-radius: 16rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-text {
  font-size: 30rpx;
  color: #1f2937;
}

.picker-text.placeholder {
  color: #9ca3af;
}

.picker-arrow {
  font-size: 24rpx;
  color: #9ca3af;
}

/* 位置选项 */
.location-options {
  display: flex;
  gap: 16rpx;
}

.location-item {
  flex: 1;
  height: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f9fafb;
  border-radius: 16rpx;
  border: 4rpx solid transparent;
  transition: all 0.2s;
}

.location-item.active {
  background: linear-gradient(135deg, #667eea10 0%, #764ba210 100%);
  border-color: #667eea;
}

.location-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.location-item text:last-child {
  font-size: 26rpx;
  color: #6b7280;
}

.location-item.active text:last-child {
  color: #667eea;
  font-weight: 500;
}

/* 弹窗底部按钮 */
.modal-footer {
  display: flex;
  padding: 24rpx 32rpx 32rpx;
  gap: 24rpx;
  border-top: 2rpx solid #f3f4f6;
}

.modal-footer .btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 500;
}

.modal-footer .btn-secondary {
  background: #f3f4f6;
  color: #6b7280;
}

.modal-footer .btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}