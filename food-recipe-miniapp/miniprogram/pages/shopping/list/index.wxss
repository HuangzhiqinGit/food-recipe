.container {
  padding: 24rpx;
  padding-bottom: 160rpx;
  min-height: 100vh;
  background: var(--bg-page);
}

/* Tab切换 */
.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 44rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.tab-item {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  transition: all 0.2s;
}

.tab-item.active {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

/* 统计栏 */
.stats-bar {
  margin-bottom: 24rpx;
}

.stats-text {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 分类筛选 */
.category-scroll {
  margin-bottom: 24rpx;
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  gap: 16rpx;
}

.category-item {
  padding: 12rpx 28rpx;
  background: #fff;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  border: 2rpx solid transparent;
}

.category-item.active {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

/* 分组标题 */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

/* 统计栏 */
.stats-bar {
  margin-bottom: 24rpx;
}

.stats-text {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 清单列表 */
.shopping-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.shopping-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.shopping-item.purchased {
  opacity: 0.7;
  background: #f9f9f9;
}

.checkbox {
  margin-right: 24rpx;
  padding: 8rpx;
}

.check-icon {
  font-size: 44rpx;
}

.item-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.item-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.item-category {
  font-size: 22rpx;
  color: #4CAF50;
  background: #E8F5E9;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.item-quantity {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.strikethrough {
  text-decoration: line-through;
  color: #999;
}

.delete-btn {
  font-size: 32rpx;
  padding: 8rpx;
  color: #999;
}

/* 一键入库按钮 */
.batch-stock-section {
  margin-top: 24rpx;
  margin-bottom: 120rpx;
}

.batch-stock-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.3);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
  margin-bottom: 8rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 添加按钮 */
.add-section {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: var(--primary);
  border-radius: 44rpx;
  color: #fff;
  font-size: 32rpx;
}

.add-icon {
  font-size: 40rpx;
  margin-right: 8rpx;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 80%;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--border);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.modal-close {
  font-size: 32rpx;
  color: var(--text-hint);
}

.modal-body {
  padding: 32rpx;
}

.modal-input {
  height: 80rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.modal-input:last-child {
  margin-bottom: 0;
}

.modal-footer {
  display: flex;
  padding: 24rpx 32rpx;
  gap: 24rpx;
  border-top: 1rpx solid var(--border);
}

.modal-footer .btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-footer .btn-secondary {
  background: #F5F5F5;
  color: var(--text-primary);
}

.modal-footer .btn-primary {
  background: var(--primary);
  color: #fff;
}

/* FAB浮动添加按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.4);
  z-index: 100;
}

.fab-icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: 300;
}

/* 历史列表 */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.history-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.history-date {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.history-count {
  font-size: 24rpx;
  color: var(--text-secondary);
  background: #E8F5E9;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.history-items {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.history-item-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  background: #f5f5f5;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.history-actions {
  display: flex;
  justify-content: flex-end;
}

.history-btn {
  font-size: 26rpx;
  color: #4CAF50;
  padding: 12rpx 24rpx;
  border: 2rpx solid #4CAF50;
  border-radius: 28rpx;
}

/* 弹窗内Picker样式 */
.picker {
  height: 80rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.picker-text {
  font-size: 28rpx;
  color: var(--text-primary);
}

.picker-arrow {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 位置选项 */
.location-options {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.location-item {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  border: 2rpx solid transparent;
}

.location-item.active {
  background: #E8F5E9;
  color: #4CAF50;
  border-color: #4CAF50;
}

/* 弹窗描述文字 */
.modal-desc {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
  text-align: center;
}

.modal-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  font-weight: 500;
}
