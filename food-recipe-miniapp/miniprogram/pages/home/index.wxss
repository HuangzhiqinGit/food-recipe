.container {
  padding: 32rpx;
  padding-bottom: 120rpx;
}

/* 欢迎语 */
.welcome-section {
  margin-bottom: 32rpx;
}

.welcome-text {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.welcome-subtext {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 临期提醒卡片 */
.warning-card {
  background: rgba(255, 152, 0, 0.1);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.warning-content {
  display: flex;
  align-items: center;
}

.warning-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.warning-info {
  flex: 1;
}

.warning-title {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: var(--accent);
  margin-bottom: 8rpx;
}

.warning-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.warning-arrow {
  font-size: 32rpx;
  color: var(--text-hint);
}

/* 安全状态 */
.safe-card {
  background: rgba(76, 175, 80, 0.1);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.safe-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.safe-text {
  font-size: 28rpx;
  color: var(--primary);
}

/* 菜谱推荐 */
.recipe-section {
  margin-top: 16rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.refresh-btn {
  font-size: 28rpx;
  color: var(--primary);
}

/* 菜谱网格 */
.recipe-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.recipe-item {
  width: calc(50% - 12rpx);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.recipe-image {
  width: 100%;
  height: 200rpx;
  background: #f5f5f5;
}

.recipe-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  padding: 16rpx 16rpx 8rpx;
}

.recipe-tags {
  display: flex;
  gap: 12rpx;
  padding: 0 16rpx 16rpx;
}
