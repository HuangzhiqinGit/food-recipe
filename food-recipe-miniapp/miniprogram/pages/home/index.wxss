.container {
  min-height: 100vh;
  background: #f8f9fa;
}

/* 固定头部区域 */
.header-fixed {
  position: sticky;
  top: 0;
  z-index: 100;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 32rpx 32rpx;
  color: white;
  transform: translateZ(0);
  will-change: transform;
  backface-visibility: hidden;
}

.header-content {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.welcome-text {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.welcome-subtext {
  font-size: 28rpx;
  opacity: 0.85;
}

/* 内容区域 - 可滚动 */
.content {
  padding: 16rpx 24rpx 40rpx;
}

/* 临期提醒卡片 */
.warning-card {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.12);
  margin-bottom: 0;
}

.warning-card:active {
  transform: scale(0.98);
}

.warning-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
}

.warning-info {
  flex: 1;
}

.warning-title {
  font-weight: 600;
  color: #1f2937;
  font-size: 30rpx;
  margin-bottom: 8rpx;
  display: block;
}

.warning-desc {
  color: #9ca3af;
  font-size: 26rpx;
  display: block;
}

.warning-arrow {
  color: #9ca3af;
  font-size: 36rpx;
  font-weight: 300;
}

/* 安全状态 */
.safe-card {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.12);
  margin-bottom: 0;
}

.safe-icon {
  font-size: 40rpx;
}

.safe-text {
  color: #6b7280;
  font-size: 28rpx;
}

/* 菜谱推荐区域 */
.recipe-section {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.08);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-weight: 600;
  color: #1f2937;
  font-size: 32rpx;
}

.refresh-btn {
  color: #667eea;
  font-size: 26rpx;
  font-weight: 500;
}

.refresh-btn:active {
  opacity: 0.7;
}

/* 菜谱网格 */
.recipe-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.recipe-card {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  border: 2rpx solid #f3f4f6;
}

.recipe-card:active {
  transform: scale(0.98);
}

.recipe-image {
  width: 100%;
  height: 180rpx;
  background: #f3f4f6;
}

.recipe-content {
  padding: 20rpx;
}

.recipe-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.recipe-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.tag {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-primary {
  background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);
  color: #6366f1;
}

.tag-accent {
  background: linear-gradient(135deg, #fce7f3 0%, #fbcfe8 100%);
  color: #ec4899;
}
