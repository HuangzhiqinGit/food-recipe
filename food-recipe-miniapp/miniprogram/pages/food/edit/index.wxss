.container {
  padding: 32rpx;
  padding-bottom: 160rpx;
  min-height: 100vh;
  background: #f8f9fa;
}

.page-header {
  margin-bottom: 48rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1f2937;
}

/* 表单 */
.form {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #374151;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.required {
  color: #ef4444;
}

.form-input {
  height: 88rpx;
  background: #f3f4f6;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1f2937;
}

/* 扫描录入卡片 - 优化后 */
.scan-section {
  margin-bottom: 32rpx;
}

.scan-card {
  background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(59, 130, 246, 0.3);
  position: relative;
  overflow: hidden;
}

.scan-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.scan-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.2);
}

.scan-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  backdrop-filter: blur(10rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  flex-shrink: 0;
}

.scan-content {
  flex: 1;
}

.scan-title {
  color: #fff;
  font-weight: 600;
  font-size: 32rpx;
  margin-bottom: 8rpx;
  display: block;
}

.scan-desc {
  color: rgba(255, 255, 255, 0.85);
  font-size: 24rpx;
  display: block;
}

.scan-arrow {
  width: 56rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  backdrop-filter: blur(10rpx);
}

.arrow-icon {
  color: #fff;
  font-size: 36rpx;
  font-weight: 300;
  line-height: 1;
}

/* 快捷标签 */
.quick-tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  margin-top: -8rpx;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
}

.quick-label {
  font-size: 24rpx;
  color: #9ca3af;
  margin-right: 16rpx;
}

.quick-tag {
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  color: #667eea;
  border-radius: 28rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
  border: 2rpx solid rgba(102, 126, 234, 0.2);
  font-weight: 500;
}

.quick-tag:active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

/* 选择器 */
.picker {
  height: 88rpx;
  background: #f3f4f6;
  border-radius: 16rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-text {
  font-size: 28rpx;
  color: #374151;
}

.picker-text.placeholder {
  color: #9ca3af;
}

.picker-arrow {
  font-size: 24rpx;
  color: #9ca3af;
}

/* 数量行 */
.quantity-row {
  display: flex;
  gap: 16rpx;
}

.quantity-input {
  flex: 1;
}

.unit-picker {
  width: 180rpx;
  justify-content: center;
}

/* 底部按钮 */
.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  display: flex;
  gap: 24rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.footer .btn {
  flex: 1;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.footer .btn-secondary {
  background: #f3f4f6;
  color: #4b5563;
}

.footer .btn-secondary:active {
  background: #e5e7eb;
}

.footer .btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.footer .btn-primary:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}
