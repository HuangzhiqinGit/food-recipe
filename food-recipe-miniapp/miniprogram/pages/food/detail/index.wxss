/* 食材详情页样式 - 优化后 */

.container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 40rpx;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
}

/* 头部信息 - 优化后带图片 */
.food-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx;
  position: relative;
}

.food-image-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.food-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 24rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
  margin-bottom: 30rpx;
  background: #fff;
}

.food-info {
  text-align: center;
}

.food-name {
  font-size: 44rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.food-category {
  display: flex;
  justify-content: center;
}

.category-tag {
  font-size: 26rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.25);
  padding: 10rpx 28rpx;
  border-radius: 30rpx;
  backdrop-filter: blur(10px);
}

/* 状态区域 - 优化后 */
.status-section {
  background: #fff;
  margin: 30rpx;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.status-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.status-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

/* 状态标签 - 渐变色 */
.status-badge {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
}

.status-badge.normal {
  background: linear-gradient(135deg, #52c234 0%, #22b322 100%);
  color: #fff;
}

.status-badge.warning {
  background: linear-gradient(135deg, #f5af19 0%, #f12711 100%);
  color: #fff;
}

.status-badge.expired {
  background: linear-gradient(135deg, #eb3349 0%, #f45c43 100%);
  color: #fff;
}

.badge-icon {
  font-size: 28rpx;
}

.badge-text {
  font-size: 26rpx;
}

/* 状态信息列表 */
.status-info-list {
  border-top: 2rpx solid #f0f0f0;
  padding-top: 20rpx;
}

.status-info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #999;
}

.info-value {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.info-value.warning {
  color: #f5af19;
  font-weight: 600;
}

.info-value.expired {
  color: #eb3349;
  font-weight: 600;
}

/* 详情卡片 */
.detail-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin: 0 30rpx 30rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f8f8f8;
}

.detail-item:last-child {
  border-bottom: none;
}

.item-label {
  font-size: 28rpx;
  color: #666;
}

.item-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 24rpx;
  margin: 40rpx 30rpx 0;
}

.btn {
  flex: 1;
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.btn-danger {
  background: #fee;
  color: #eb3349;
}

.btn-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

/* 空状态 */
.empty-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 600rpx;
}
