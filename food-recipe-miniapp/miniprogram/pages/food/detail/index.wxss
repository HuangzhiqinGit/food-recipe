/* 食材详情页样式 */

.container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding: 20rpx;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
}

/* 头部信息 */
.food-header {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.food-icon {
  font-size: 80rpx;
  margin-right: 30rpx;
}

.food-info {
  flex: 1;
}

.food-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.food-category {
  display: flex;
  align-items: center;
}

.category-tag {
  font-size: 24rpx;
  color: #4CAF50;
  background: rgba(76, 175, 80, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

/* 状态卡片 */
.status-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border-left: 8rpx solid #4CAF50;
}

.status-card.warning {
  border-left-color: #FF9800;
  background: linear-gradient(135deg, #fff 0%, rgba(255, 152, 0, 0.05) 100%);
}

.status-card.expired {
  border-left-color: #F44336;
  background: linear-gradient(135deg, #fff 0%, rgba(244, 67, 54, 0.05) 100%);
}

.status-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.status-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.status-label {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.expire-date {
  font-size: 24rpx;
  color: #999;
}

/* 详情卡片 */
.detail-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #F5F5F5;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #F5F5F5;
}

.detail-item:last-child {
  border-bottom: none;
}

.item-label {
  font-size: 28rpx;
  color: #666;
}

.item-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  border: none;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: #fff;
}

.btn-danger {
  background: linear-gradient(135deg, #F44336 0%, #d32f2f 100%);
  color: #fff;
}

.btn-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

/* 空状态 */
.empty-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 600rpx;
}
