<view class="container">
  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-container">
    <loading />
  </view>

  <!-- 内容区域 -->
  <block wx:elif="{{food}}">
    <!-- 食材头部信息 - 优化后带图片 -->
    <view class="food-header">
      <view class="food-image-wrap">
        <image 
          class="food-image" 
          src="{{food.imageUrl || '/assets/images/empty-food.png'}}" 
          mode="aspectFill"
          bindtap="previewImage"
        />
        <view class="food-info">
          <text class="food-name">{{food.name}}</text>
          <view class="food-category">
            <text class="category-tag">{{getCategoryIcon(food.category)}} {{getCategoryName(food.category)}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 状态卡片 - 优化后，复用后端返回的status -->
    <view class="status-section">
      <view class="status-header">
        <text class="status-title">保鲜状态</text>
        <view class="status-badge {{food.status || 'fresh'}}">
          <text class="badge-icon">{{getStatusIcon(food.status)}}</text>
          <text class="badge-text">{{food.statusText || '新鲜'}}</text>
        </view>
      </view>
      <view class="status-info-list">
        <view class="status-info-item" wx:if="{{food.expireDate}}">
          <text class="info-label">过期日期</text>
          <text class="info-value {{food.status}}">{{food.expireDate}}</text>
        </view>
        <view class="status-info-item" wx:if="{{food.expireDate}}">
          <text class="info-label">剩余天数</text>
          <text class="info-value {{food.status}}">{{getExpireCountdown(food.expireDate)}}</text>
        </view>
      </view>
    </view>

    <!-- 详细信息卡片 - 时间格式化 -->
    <view class="detail-card">
      <view class="card-title">详细信息</view>
      
      <view class="detail-item">
        <text class="item-label">数量</text>
        <text class="item-value">{{food.quantity}} {{food.unit}}</text>
      </view>
      
      <view class="detail-item">
        <text class="item-label">存放位置</text>
        <text class="item-value">{{food.location}}</text>
      </view>
      
      <view class="detail-item">
        <text class="item-label">添加时间</text>
        <text class="item-value">{{formatDateTime(food.createdAt)}}</text>
      </view>
      
      <view class="detail-item" wx:if="{{food.updatedAt}}">
        <text class="item-label">更新时间</text>
        <text class="item-value">{{formatDateTime(food.updatedAt)}}</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-buttons">
      <button class="btn btn-primary" bindtap="goToEdit">
        <text class="btn-icon">✏️</text>
        <text>编辑</text>
      </button>
      <button class="btn btn-danger" bindtap="deleteFood">
        <text class="btn-icon">🗑️</text>
        <text>删除</text>
      </button>
    </view>
  </block>

  <!-- 空状态 -->
  <view wx:else class="empty-container">
    <empty-state title="食材不存在" description="该食材可能已被删除" />
  </view>
</view>
