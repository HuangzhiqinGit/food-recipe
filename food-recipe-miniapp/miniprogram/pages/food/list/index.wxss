.container {
  padding: 0;
  padding-bottom: 120rpx;
  background: #f8f9fa;
  min-height: 100vh;
}

/* 登录提示 */
.login-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.tip-icon {
  font-size: 100rpx;
  margin-bottom: 32rpx;
}

.tip-text {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-bottom: 48rpx;
}

.login-btn-wrapper {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 24rpx 80rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.login-btn-wrapper:active,
.login-btn-wrapper.login-btn-hover {
  opacity: 0.9;
  transform: translateY(2rpx);
}

.login-btn-text {
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
}

.login-sub-tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 24rpx;
}

/* 固定头部区域 - 合并搜索栏+状态筛选+分类标签 */
.header-fixed {
  position: sticky;
  top: 0;
  z-index: 100;
  background: #f8f9fa;
  padding: 24rpx 24rpx 16rpx;
  transform: translateZ(0);
  will-change: transform;
  backface-visibility: hidden;
  border-bottom: 8rpx solid #f8f9fa;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 44rpx;
  padding: 0 24rpx;
  height: 80rpx;
  margin-right: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  color: #9ca3af;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #374151;
}

.add-btn {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.add-btn:active {
  transform: scale(0.95);
}

.add-icon {
  color: #fff;
  font-size: 48rpx;
  font-weight: 300;
  line-height: 1;
}

/* 状态筛选 */
.status-scroll {
  margin-bottom: 16rpx;
  white-space: nowrap;
}

.status-list {
  display: inline-flex;
  gap: 16rpx;
}

.status-item {
  padding: 14rpx 32rpx;
  background: #fff;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #6b7280;
  border: 2rpx solid transparent;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s;
}

.status-item.active {
  color: #fff;
  font-weight: 500;
}

/* 新鲜 - 绿色渐变 */
.status-item.active.status-fresh {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  box-shadow: 0 4rpx 16rpx rgba(16, 185, 129, 0.4);
}

/* 临期 - 橙色渐变 */
.status-item.active.status-expiring {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  box-shadow: 0 4rpx 16rpx rgba(245, 158, 11, 0.4);
}

/* 已过期 - 红色渐变 */
.status-item.active.status-expired {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  box-shadow: 0 4rpx 16rpx rgba(239, 68, 68, 0.4);
}

/* 全部 - 紫色渐变 */
.status-item.active.status-all {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.4);
}

/* 分类标签 */
.category-scroll {
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  gap: 16rpx;
}

.category-item {
  padding: 14rpx 32rpx;
  background: #fff;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #6b7280;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s;
}

.category-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

/* 食材列表 */
.food-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0 24rpx;
}

.food-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  gap: 24rpx;
  transition: transform 0.2s;
}

.food-card:active {
  transform: scale(0.98);
}

.food-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f3f4f6;
}

.food-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.food-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.food-name-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.food-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.arrow {
  color: #9ca3af;
  font-size: 32rpx;
  font-weight: 300;
}

.food-info {
  margin-bottom: 8rpx;
}

.info-text {
  font-size: 26rpx;
  color: #6b7280;
}

.food-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.meta-text {
  font-size: 22rpx;
  color: #9ca3af;
  background: #f3f4f6;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* 状态标识 - 优化后 */
.food-status-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: auto;
}

.status-badge {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 18rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}

/* 新鲜状态 - 绿色渐变 */
.status-badge.status-fresh {
  background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
  color: #065f46;
}

.status-badge.status-fresh .status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #10b981;
  box-shadow: 0 0 12rpx rgba(16, 185, 129, 0.6);
}

/* 临期状态 - 橙色渐变 */
.status-badge.status-expiring {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  color: #92400e;
}

.status-badge.status-expiring .status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #f59e0b;
  box-shadow: 0 0 12rpx rgba(245, 158, 11, 0.6);
  animation: pulse 2s infinite;
}

/* 已过期状态 - 红色渐变 */
.status-badge.status-expired {
  background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
  color: #991b1b;
}

.status-badge.status-expired .status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #ef4444;
  box-shadow: 0 0 12rpx rgba(239, 68, 68, 0.6);
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.7;
    transform: scale(1.1);
  }
}

.expire-countdown {
  color: #9ca3af;
  font-size: 24rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
  margin-bottom: 32rpx;
}

.quick-add-list {
  display: flex;
  gap: 16rpx;
}

.quick-add-item {
  padding: 14rpx 28rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  color: #667eea;
  border-radius: 28rpx;
  font-size: 26rpx;
  font-weight: 500;
  border: 2rpx solid rgba(102, 126, 234, 0.2);
}

.quick-add-item:active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

/* 悬浮添加按钮 - FAB */
.fab-btn {
  position: fixed;
  bottom: 120rpx;
  right: 40rpx;
  width: 112rpx;
  height: 112rpx;
  z-index: 100;
}

.fab-inner {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.5);
  transition: all 0.3s;
}

.fab-btn:active .fab-inner {
  transform: scale(0.95) rotate(45deg);
  box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.4);
}

.fab-icon {
  color: #fff;
  font-size: 56rpx;
  font-weight: 200;
  line-height: 1;
}
