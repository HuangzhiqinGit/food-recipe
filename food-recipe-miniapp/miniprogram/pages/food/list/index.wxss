.container {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* 登录提示 */
.login-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.tip-icon {
  font-size: 100rpx;
  margin-bottom: 32rpx;
}

.tip-text {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-bottom: 48rpx;
}

.login-btn-wrapper {
  background: #4CAF50;
  padding: 24rpx 80rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn-wrapper:active,
.login-btn-wrapper.login-btn-hover {
  opacity: 0.8;
  background: #388E3C;
}

.login-btn-text {
  color: #fff;
  font-size: 30rpx;
}

.login-sub-tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 24rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 44rpx;
  padding: 0 24rpx;
  height: 80rpx;
  margin-right: 16rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.add-btn {
  width: 80rpx;
  height: 80rpx;
  background: var(--accent);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon {
  color: #fff;
  font-size: 48rpx;
  font-weight: 300;
  line-height: 1;
}

/* 状态筛选 */
.status-scroll {
  margin-bottom: 16rpx;
  white-space: nowrap;
}

.status-list {
  display: inline-flex;
  gap: 16rpx;
}

.status-item {
  padding: 12rpx 28rpx;
  background: #fff;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  border: 2rpx solid transparent;
}

.status-item.active {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.status-item.active[data-value="expiring"] {
  background: linear-gradient(135deg, #FF9800 0%, #F57C00 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.3);
}

.status-item.active[data-value="expired"] {
  background: linear-gradient(135deg, #F44336 0%, #D32F2F 100%);
  box-shadow: 0 4rpx 12rpx rgba(244, 67, 54, 0.3);
}

/* 分类标签 */
.category-scroll {
  margin-bottom: 24rpx;
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  gap: 16rpx;
}

.category-item {
  padding: 12rpx 28rpx;
  background: #fff;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: all 0.2s;
}

.category-item.active {
  background: var(--primary);
  color: #fff;
}

/* 食材列表 */
.food-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.food-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  display: flex;
  gap: 24rpx;
}

.food-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.food-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.food-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.food-name-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.status-dot-fresh {
  background: #4CAF50;
}

.status-dot-warning {
  background: #FF9800;
}

.status-dot-danger {
  background: #F44336;
}

.food-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.arrow {
  color: var(--text-hint);
  font-size: 28rpx;
}

.food-info {
  margin-bottom: 8rpx;
}

.info-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.food-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.meta-text {
  font-size: 22rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.food-status {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
}

.tag {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.tag-primary {
  background: #E8F5E9;
  color: #4CAF50;
}

.tag-accent {
  background: #FFF3E0;
  color: #FF9800;
}

.tag-danger {
  background: #FFEBEE;
  color: #F44336;
}

.expire-text {
  font-size: 22rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
  margin-bottom: 32rpx;
}

.quick-add-list {
  display: flex;
  gap: 16rpx;
}

.quick-add-item {
  padding: 12rpx 24rpx;
  background: rgba(76, 175, 80, 0.1);
  color: var(--primary);
  border-radius: 28rpx;
  font-size: 26rpx;
}
