.container {
  padding: 0 0 120rpx;
  background: #f8f9fa;
  min-height: 100vh;
}

/* 登录提示 */
.login-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.tip-icon {
  font-size: 100rpx;
  margin-bottom: 32rpx;
}

.tip-text {
  font-size: 32rpx;
  color: #6b7280;
  margin-bottom: 48rpx;
}

.login-btn-wrapper {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 24rpx 80rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
  margin-bottom: 16rpx;
}

.login-btn-wrapper:active {
  transform: translateY(2rpx);
}

.login-btn-text {
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
}

.login-sub-tip {
  font-size: 24rpx;
  color: #9ca3af;
}

/* 固定头部区域 */
.header-fixed {
  position: sticky;
  top: 0;
  z-index: 100;
  background: #f8f9fa;
  padding: 24rpx 24rpx 16rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  color: #9ca3af;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1f2937;
}

/* 状态筛选横向滚动 */
.status-scroll {
  white-space: nowrap;
  margin-bottom: 16rpx;
}

.status-list {
  display: inline-flex;
  gap: 16rpx;
}

.status-item {
  padding: 14rpx 32rpx;
  background: #fff;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #6b7280;
  border: 2rpx solid transparent;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.status-item.active {
  color: #fff;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

/* 分类标签横向滚动 */
.category-scroll {
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  gap: 12rpx;
}

.category-item {
  padding: 12rpx 28rpx;
  background: #fff;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #6b7280;
  border: 2rpx solid #e5e7eb;
}

.category-item.active {
  color: #667eea;
  border-color: #667eea;
  background: rgba(102, 126, 234, 0.08);
}

/* 食材列表 */
.food-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 16rpx 24rpx;
}

.food-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.food-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f3f4f6;
}

.food-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.food-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.food-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.arrow {
  color: #9ca3af;
  font-size: 32rpx;
}

.food-info {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.food-meta {
  display: flex;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.meta-text {
  font-size: 22rpx;
  color: #9ca3af;
}

.food-status-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.status-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.status-fresh {
  background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
  color: #059669;
}

.status-fresh .status-dot {
  background: #10b981;
}

.status-expiring {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  color: #d97706;
}

.status-expiring .status-dot {
  background: #f59e0b;
}

.status-expired {
  background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
  color: #dc2626;
}

.status-expired .status-dot {
  background: #ef4444;
}

.expire-countdown {
  font-size: 22rpx;
  color: #ef4444;
  font-weight: 500;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
  margin-bottom: 32rpx;
}

.quick-add-list {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.quick-add-item {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 32rpx;
  font-size: 26rpx;
}

/* 悬浮添加按钮 */
.fab-btn {
  position: fixed;
  bottom: 40rpx;
  right: 40rpx;
  width: 112rpx;
  height: 112rpx;
  z-index: 100;
}

.fab-inner {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.5);
}

.fab-icon {
  color: #fff;
  font-size: 56rpx;
  font-weight: 200;
}