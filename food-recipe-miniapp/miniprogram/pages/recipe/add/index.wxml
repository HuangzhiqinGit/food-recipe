<view class="container">
  <view class="page-header">
    <text class="page-title">添加个人菜谱</text>
  </view>

  <!-- 表单 -->
  <view class="form">
    <!-- 食谱图片 -->
    <view class="form-item">
      <text class="form-label">食谱图片 <text class="optional">（最多5张）</text></text>
      <image-uploader images="{{images}}" maxCount="5" type="recipe" bind:change="onImageChange"/>
    </view>

    <!-- 菜名 -->
    <view class="form-item">
      <text class="form-label">菜名 <text class="required">*</text></text>
      <input 
        class="form-input" 
        placeholder="请输入菜名"
        value="{{form.name}}"
        bindinput="onNameInput"
      />
    </view>

    <!-- 荤素类型 -->
    <view class="form-item">
      <text class="form-label">荤素类型 <text class="required">*</text></text>
      <picker bindchange="onTypeChange" value="{{typeIndex}}" range="{{typeOptions}}" range-key="label">
        <view class="picker">
          <text class="picker-text">{{typeOptions[typeIndex].label}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <!-- 烹饪时长 -->
    <view class="form-item">
      <text class="form-label">烹饪时长 <text class="required">*</text></text>
      <picker bindchange="onDurationChange" value="{{durationIndex}}" range="{{durationOptions}}" range-key="label">
        <view class="picker">
          <text class="picker-text">{{durationOptions[durationIndex].label}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <!-- 所需食材 -->
    <view class="form-item">
      <view class="label-row">
        <text class="form-label">所需食材 <text class="required">*</text></text>
        <text class="add-link" bindtap="addIngredient">+ 添加食材</text>
      </view>
      <view class="ingredient-list">
        <view class="ingredient-item" wx:for="{{form.ingredients}}" wx:key="index">
          <input 
            class="ingredient-input name-input" 
            placeholder="食材名"
            value="{{item.name}}"
            data-index="{{index}}"
            data-field="name"
            bindinput="onIngredientInput"
          />
          <input 
            class="ingredient-input qty-input" 
            placeholder="数量"
            value="{{item.quantity}}"
            data-index="{{index}}"
            data-field="quantity"
            bindinput="onIngredientInput"
          />
          <input 
            class="ingredient-input unit-input" 
            placeholder="单位"
            value="{{item.unit}}"
            data-index="{{index}}"
            data-field="unit"
            bindinput="onIngredientInput"
          />
          <text class="delete-btn" bindtap="deleteIngredient" data-index="{{index}}">🗑️</text>
        </view>
      </view>
    </view>

    <!-- 烹饪步骤 -->
    <view class="form-item">
      <view class="label-row">
        <text class="form-label">烹饪步骤 <text class="required">*</text></text>
        <text class="add-link" bindtap="addStep">+ 添加步骤</text>
      </view>
      <view class="step-list">
        <view class="step-item" wx:for="{{form.steps}}" wx:key="index">
          <text class="step-number">{{index + 1}}.</text>
          <textarea 
            class="step-input" 
            placeholder="请输入步骤内容"
            value="{{item}}"
            data-index="{{index}}"
            bindinput="onStepInput"
          />
          <text class="delete-btn" bindtap="deleteStep" data-index="{{index}}">🗑️</text>
        </view>
      </view>
    </view>

    <!-- 小贴士 -->
    <view class="form-item">
      <text class="form-label">小贴士</text>
      <textarea 
        class="form-textarea" 
        placeholder="请输入烹饪小贴士（选填）"
        value="{{form.tips}}"
        bindinput="onTipsInput"
      />
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="footer">
    <button class="btn btn-secondary" bindtap="onCancel">取消</button>
    <button class="btn btn-primary" bindtap="onSave">保存</button>
  </view>
</view>
