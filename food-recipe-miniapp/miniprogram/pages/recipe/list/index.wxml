<view class="container">
  <!-- 固定头部 -->
  <view class="header-fixed">
    <view class="action-bar">
      <view class="btn btn-match" bindtap="matchByInventory">
        <text class="btn-icon">🔍</text>
        <text>按库存找菜谱</text>
      </view>
      <view class="btn btn-filter" bindtap="goToFilter">
        <text>筛选</text>
      </view>
    </view>
    
    <view class="tab-bar">
      <view class="tab-item {{currentTab === 'recommend' ? 'active' : ''}}" bindtap="switchTab" data-tab="recommend">随机推荐</view>
      <view class="tab-item {{currentTab === 'favorite' ? 'active' : ''}}" bindtap="switchTab" data-tab="favorite">我的收藏</view>
    </view>
  </view>

  <!-- 菜谱列表 -->
  <view class="recipe-list" wx:if="{{recipeList.length > 0}}">
    <view class="recipe-card" wx:for="{{recipeList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <image class="recipe-image" src="{{item.displayImage}}" mode="aspectFill"/>
      <view class="recipe-info">
        <text class="recipe-name">{{item.name}}</text>
        <view class="recipe-tags">
          <text class="tag tag-primary">{{item.typeName}}</text>
          <text class="tag tag-accent">{{item.durationName}}</text>
        </view>
        <text class="match-rate" wx:if="{{item.matchRate}}">匹配度: {{item.matchRate}}%</text>
      </view>
      <view class="favorite-icon" wx:if="{{item.isFavorite}}">⭐</view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <image class="empty-icon" src="/assets/images/empty-recipe.png" mode="aspectFit"/>
    <text class="empty-text">{{currentTab === 'favorite' ? '暂无收藏菜谱' : '暂无匹配菜谱，快去添加食材吧~'}}</text>
    <view class="action-link" bindtap="goToFoodList" wx:if="{{currentTab === 'recommend'}}">去添加食材 ></text>
  </view>

  <!-- 悬浮按钮 -->
  <view class="fab-btn" bindtap="goToAddRecipe">
    <view class="fab-inner">
      <text class="fab-icon">+</text>
    </view>
  </view>
</view>