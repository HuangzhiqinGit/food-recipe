.container {
  padding: 0;
  padding-bottom: 120rpx;
  background: #f8f9fa;
  min-height: 100vh;
  position: relative;
}

/* 操作栏 - 固定 */
.action-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  background: #f8f9fa;
  padding: 24rpx 24rpx 16rpx;
  display: flex;
  gap: 16rpx;
}

.action-bar .btn {
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-match {
  flex: 1;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.btn-match:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.2);
}

.btn-filter {
  width: 140rpx;
  background: #fff;
  color: #6b7280;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.btn-filter:active {
  background: #f3f4f6;
}

.btn-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

/* 悬浮添加按钮 - 优化后 */
.fab-btn {
  position: fixed;
  bottom: 120rpx;
  right: 40rpx;
  width: 120rpx;
  height: 120rpx;
  z-index: 100;
}

.fab-inner {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.5);
  transition: all 0.3s;
}

.fab-btn:active .fab-inner {
  transform: scale(0.95) rotate(45deg);
  box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.4);
}

.fab-icon {
  color: #fff;
  font-size: 56rpx;
  font-weight: 200;
  line-height: 1;
}

/* 标签栏 - 固定 */
.tab-bar {
  position: sticky;
  top: 120rpx;
  z-index: 99;
  background: #f8f9fa;
  padding: 0 24rpx 16rpx;
  display: flex;
  margin-bottom: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.tab-item {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #9ca3af;
  position: relative;
  transition: all 0.2s;
}

.tab-item.active {
  color: #667eea;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 3rpx;
}

/* 菜谱列表 */
.recipe-list {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  padding: 0 24rpx 120rpx;
}

.recipe-card {
  width: calc(50% - 12rpx);
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  position: relative;
  transition: transform 0.2s;
}

.recipe-card:active {
  transform: scale(0.98);
}

.recipe-image {
  width: 100%;
  height: 220rpx;
  background: #f3f4f6;
}

.recipe-info {
  padding: 20rpx;
}

.recipe-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recipe-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 8rpx;
  flex-wrap: wrap;
}

.tag {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-primary {
  background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);
  color: #6366f1;
}

.tag-accent {
  background: linear-gradient(135deg, #fce7f3 0%, #fbcfe8 100%);
  color: #ec4899;
}

.match-rate {
  font-size: 24rpx;
  color: #10b981;
  font-weight: 500;
}

.favorite-icon {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  font-size: 36rpx;
  background: rgba(255, 255, 255, 0.9);
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  margin-top: 16rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
  margin-bottom: 24rpx;
  text-align: center;
}

.action-link {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 500;
}
