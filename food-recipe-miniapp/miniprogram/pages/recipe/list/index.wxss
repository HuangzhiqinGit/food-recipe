.container {
  padding: 0 0 120rpx;
  background: #f8f9fa;
  min-height: 100vh;
}

/* 固定头部 */
.header-fixed {
  position: sticky;
  top: 0;
  z-index: 100;
  background: #f8f9fa;
  padding: 24rpx 24rpx 16rpx;
}

/* 操作栏 */
.action-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.btn-match {
  flex: 1;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.btn-filter {
  width: 140rpx;
  height: 80rpx;
  background: #fff;
  color: #6b7280;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.btn-icon {
  margin-right: 8rpx;
}

/* Tab栏 */
.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.tab-item {
  flex: 1;
  padding: 24rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: #6b7280;
}

.tab-item.active {
  color: #667eea;
  font-weight: 600;
  background: rgba(102, 126, 234, 0.08);
}

/* 菜谱列表 */
.recipe-list {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  padding: 16rpx 24rpx;
}

.recipe-card {
  width: calc(50% - 12rpx);
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.recipe-image {
  width: 100%;
  height: 240rpx;
}

.recipe-info {
  padding: 20rpx;
}

.recipe-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  display: block;
  margin-bottom: 12rpx;
}

.recipe-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.tag {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.tag-primary {
  background: #eef2ff;
  color: #667eea;
}

.tag-accent {
  background: #fef3c7;
  color: #d97706;
}

.match-rate {
  font-size: 24rpx;
  color: #10b981;
}

.favorite-icon {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  font-size: 40rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
  margin-bottom: 24rpx;
}

.action-link {
  color: #667eea;
  font-size: 28rpx;
}

/* 悬浮按钮 */
.fab-btn {
  position: fixed;
  bottom: 40rpx;
  right: 40rpx;
  width: 112rpx;
  height: 112rpx;
  z-index: 100;
}

.fab-inner {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.5);
}

.fab-icon {
  color: #fff;
  font-size: 56rpx;
  font-weight: 200;
}
