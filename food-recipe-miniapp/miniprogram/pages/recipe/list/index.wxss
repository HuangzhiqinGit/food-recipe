.container {
  padding: 24rpx;
  padding-bottom: 120rpx;
  background: var(--bg-page);
  min-height: 100vh;
}

/* 操作栏 */
.action-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.action-bar .btn {
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.btn-match {
  flex: 1;
  background: var(--accent);
  color: #fff;
}

.btn-filter {
  width: 120rpx;
  background: #F5F5F5;
  color: var(--text-secondary);
}

.btn-add {
  width: 72rpx;
  background: var(--accent);
  color: #fff;
  font-size: 40rpx;
}

.btn-icon {
  margin-right: 8rpx;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  margin-bottom: 24rpx;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-secondary);
  position: relative;
}

.tab-item.active {
  color: var(--primary);
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: var(--primary);
  border-radius: 2rpx;
}

/* 菜谱列表 */
.recipe-list {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.recipe-card {
  width: calc(50% - 12rpx);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  position: relative;
}

.recipe-image {
  width: 100%;
  height: 200rpx;
  background: #f5f5f5;
}

.recipe-info {
  padding: 16rpx;
}

.recipe-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recipe-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.tag {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.tag-primary {
  background: rgba(76, 175, 80, 0.1);
  color: var(--primary);
}

.tag-accent {
  background: rgba(255, 152, 0, 0.1);
  color: var(--accent);
}

.match-rate {
  font-size: 24rpx;
  color: var(--primary);
}

.favorite-icon {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  font-size: 32rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
  margin-bottom: 24rpx;
  text-align: center;
}

.action-link {
  font-size: 28rpx;
  color: var(--primary);
}
