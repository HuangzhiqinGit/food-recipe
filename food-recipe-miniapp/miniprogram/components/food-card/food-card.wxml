<view class="food-card" bindtap="onTap" bindlongpress="onLongPress">
  <view class="food-icon">{{getCategoryIcon(food.category)}}</view>
  <view class="food-info">
    <view class="food-header-row">
      <text class="food-name">{{food.name}}</text>
      <view wx:if="{{food.expireDate}}" class="expire-badge {{getStatusClass(getRemainingDays(food.expireDate))}}">
        <text wx:if="{{getRemainingDays(food.expireDate) < 0}}">已过期{{Math.abs(getRemainingDays(food.expireDate))}}天</text>
        <text wx:elif="{{getRemainingDays(food.expireDate) === 0}}">今天过期</text>
        <text wx:else>{{getRemainingDays(food.expireDate)}}天后过期</text>
      </view>
    </view>
    <view class="food-meta">
      <text class="category-tag">{{getCategoryName(food.category)}}</text>
      <text class="quantity">{{food.quantity}}{{food.unit}}</text>
      <text class="location">{{food.location}}</text>
    </view>
  </view>
  <view class="arrow">›</view>
</view>
