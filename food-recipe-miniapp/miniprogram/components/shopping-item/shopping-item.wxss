/* 购物清单项组件 */

.shopping-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.shopping-item.completed {
  opacity: 0.6;
}

.checkbox {
  margin-right: 20rpx;
}

.check-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 4rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  transition: all 0.2s;
}

.check-circle.checked {
  background: #4CAF50;
  border-color: #4CAF50;
}

.item-content {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.item-name {
  font-size: 30rpx;
  color: #333;
}

.shopping-item.completed .item-name {
  text-decoration: line-through;
  color: #999;
}

.item-quantity {
  font-size: 24rpx;
  color: #666;
  background: #F5F5F5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.item-actions {
  margin-left: 16rpx;
}

.delete-btn {
  font-size: 36rpx;
  padding: 10rpx;
}
